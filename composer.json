{
    "name": "candycore/sugar-wishlist",
    "description": "SSH endpoint launcher — a TUI directory of `ssh user@host` shortcuts. Port of charmbracelet/wishlist. Loads endpoints from YAML/JSON, renders an interactive picker, then `exec`s into the chosen ssh client (with full host-key prompt / agent forwarding fidelity).",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "candycore",
        "wishlist",
        "ssh",
        "launcher",
        "directory",
        "tui",
        "charm",
        "picker"
    ],
    "homepage": "https://github.com/sugarcraft/sugar-wishlist",
    "authors": [
        {
            "name": "Joe Huss",
            "email": "detain@interserver.net",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/sugarcraft/sugar-wishlist/issues",
        "source": "https://github.com/sugarcraft/sugar-wishlist",
        "docs":   "https://sugarcraft.github.io/lib/sugar-wishlist.html"
    },
    "bin": ["bin/wishlist"],
    "require": {
        "php": ">=8.1",
        "ext-pcntl": "*",
        "candycore/candy-core": "@dev",
        "candycore/sugar-bits": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "CandyCore\\Wishlist\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CandyCore\\Wishlist\\Tests\\": "tests/"
        }
    },
    "repositories": [
        { "type": "path", "url": "../candy-core",      "options": { "symlink": true } },
        { "type": "path", "url": "../candy-sprinkles", "options": { "symlink": true } },
        { "type": "path", "url": "../honey-bounce",    "options": { "symlink": true } },
        { "type": "path", "url": "../sugar-bits",      "options": { "symlink": true } }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
